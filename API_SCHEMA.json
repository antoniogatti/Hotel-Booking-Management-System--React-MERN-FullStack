    {
      "group": "Booking.com Integration",
      "basePath": "/api/integrations/booking-com"
    },
    {
      "method": "GET",
      "path": "/api/integrations/booking-com/export/:hotelId/:token.ics",
      "auth": "none",
      "description": "Public iCal export endpoint consumed by Booking.com. The token is a per-hotel secret stored in the hotel record.",
      "pathParams": {
        "hotelId": "string – MongoDB ObjectId",
        "token": "string – hotel-specific export token"
      }
    },
    {
      "method": "PUT",
      "path": "/api/integrations/booking-com/rooms/:hotelId/config",
      "auth": "bearer",
      "requiredRole": "hotel_owner|admin",
      "description": "Updates Booking.com iCal sync configuration for a hotel.",
      "pathParams": {
        "hotelId": "string"
      },
      "requestBody": {
        "bookingComIcalUrl": "string (optional) – Booking.com iCal URL to import",
        "syncEnabled": "boolean (optional)"
      }
    },
    {
      "method": "POST",
      "path": "/api/integrations/booking-com/rooms/:hotelId/export-token/regenerate",
      "auth": "bearer",
      "requiredRole": "hotel_owner|admin",
      "description": "Regenerates the iCal export token for a hotel. Invalidates the previous token.",
      "pathParams": {
        "hotelId": "string"
      }
    },
    {
      "method": "POST",
      "path": "/api/integrations/booking-com/sync",
      "auth": "bearer",
      "requiredRole": "hotel_owner|admin",
      "description": "Triggers an immediate iCal sync from Booking.com for all configured hotels or a specific one.",
      "requestBody": {
        "hotelId": "string (optional) – if omitted, syncs all hotels"
      }
    },

