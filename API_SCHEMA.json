{
  "_meta": {
    "title": "Palazzo Pinto B&B – Backend API Schema",
    "version": "1.11.6",
    "baseUrl": "https://api.palazzopintobnb.com",
    "generated": "2026-05-30",
    "authSchemes": {
      "none": "No authentication required",
      "bearer": "Authorization: Bearer <jwt>  — obtained from POST /api/auth/login or POST /api/auth/service",
      "cookie": "Alternatively, the JWT can be sent as an HttpOnly cookie named 'auth_token'",
      "aad": "Azure AD access token (Bearer) also accepted on routes marked as 'bearer|aad'"
    },
    "roles": {
      "guest": "Unauthenticated public user",
      "user": "Authenticated registered user",
      "hotel_owner": "Hotel owner – can manage own hotels and bookings",
      "admin": "Full access to everything"
    },
    "agentNotes": {
      "serviceAuth": "Sofia Hermes authenticates via POST /api/auth/service using SOFIA_CLIENT_ID / SOFIA_CLIENT_SECRET and receives a JWT. Use that JWT as Bearer on all protected routes.",
      "pagination": "Most list endpoints support ?pageNumber=<n> (1-based). Response includes { data, pagination: { total, page, pages } }",
      "dates": "All dates are ISO 8601 strings (YYYY-MM-DD or full ISO timestamp)"
    }
  },

  "endpoints": [

    {
      "group": "Authentication",
      "basePath": "/api/auth"
    },
    {
      "method": "POST",
      "path": "/api/auth/login",
      "auth": "none",
      "description": "Login with email + password. Returns JWT as cookie and in response body.",
      "requestBody": {
        "email": "string (required)",
        "password": "string (required)"
      },
      "response": {
        "userId": "string",
        "email": "string",
        "firstName": "string",
        "lastName": "string",
        "roles": ["string"]
      }
    },
    {
      "method": "POST",
      "path": "/api/auth/service",
      "auth": "none",
      "description": "Service account authentication for AI agents and integrations. Returns a JWT.",
      "requestBody": {
        "client_id": "string (required) – value of SOFIA_CLIENT_ID env var",
        "client_secret": "string (required)"
      },
      "response": {
        "token": "string (JWT)",
        "user": {
          "userId": "string",
          "email": "string",
          "roles": ["string"]
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/auth/validate-token",
      "auth": "bearer|aad",
      "description": "Validates current session token (app JWT or Azure AD token). Returns user profile and roles.",
      "response": {
        "userId": "string",
        "email": "string",
        "firstName": "string",
        "lastName": "string",
        "roles": ["string"],
        "authProvider": "app | aad"
      }
    },
    {
      "method": "POST",
      "path": "/api/auth/logout",
      "auth": "none",
      "description": "Clears the auth cookie. Safe to call without being authenticated."
    },
    {
      "method": "GET",
      "path": "/api/auth/microsoft",
      "auth": "none",
      "description": "Initiates Microsoft OAuth2 (PKCE) login flow. Redirects browser to Microsoft."
    },
    {
      "method": "GET",
      "path": "/api/auth/callback/microsoft",
      "auth": "none",
      "description": "Microsoft OAuth2 callback. Exchanges code for token, creates/updates user, sets cookie, redirects to frontend."
    },
    {
      "method": "GET",
      "path": "/api/auth/google",
      "auth": "none",
      "description": "Google OAuth – DISABLED (returns 410). Use /api/auth/microsoft instead."
    },

    {
      "group": "Users",
      "basePath": "/api/users"
    },
    {
      "method": "POST",
      "path": "/api/users/register",
      "auth": "none",
      "description": "Register a new user account.",
      "requestBody": {
        "firstName": "string (required)",
        "lastName": "string (required)",
        "email": "string (required)",
        "password": "string (required, min 6 chars)"
      },
      "response": {
        "token": "string (JWT)"
      }
    },
    {
      "method": "GET",
      "path": "/api/users/me",
      "auth": "bearer",
      "requiredRole": "user",
      "description": "Returns the authenticated user's profile.",
      "response": {
        "_id": "string",
        "email": "string",
        "firstName": "string",
        "lastName": "string",
        "roles": ["string"]
      }
    },

    {
      "group": "Public Room Search",
      "basePath": "/api/rooms",
      "note": "These routes are public (no auth). Use withCredentials:false when calling from browser."
    },
    {
      "method": "GET",
      "path": "/api/rooms/search",
      "auth": "none",
      "description": "Search rooms. When no filters are provided, returns ALL active rooms (full catalogue). When filters are provided, applies availability and pagination.",
      "queryParams": {
        "destination": "string (optional) – city/country filter",
        "checkIn": "string (optional) – ISO date YYYY-MM-DD",
        "checkOut": "string (optional) – ISO date YYYY-MM-DD",
        "adultCount": "number (optional)",
        "childCount": "number (optional)",
        "facilities": "string[] (optional) – comma-separated amenities",
        "types": "string[] (optional) – room types",
        "stars": "number (optional)",
        "maxPrice": "number (optional)",
        "sortOption": "string (optional) – 'starRating'|'pricePerNightAsc'|'pricePerNightDesc'",
        "pageNumber": "number (optional, default 1) – only used when filters are present"
      },
      "response": {
        "data": ["HotelPublic"],
        "pagination": {
          "total": "number",
          "page": "number",
          "pages": "number"
        }
      }
    },
    {
      "method": "GET",
      "path": "/api/rooms",
      "auth": "none",
      "description": "Returns all hotels/rooms sorted by last-updated. No filtering.",
      "response": ["HotelPublic"]
    },
    {
      "method": "GET",
      "path": "/api/rooms/:id",
      "auth": "none",
      "description": "Returns full public details for a single hotel/room by MongoDB ID.",
      "pathParams": {
        "id": "string – MongoDB ObjectId"
      },
      "response": "HotelPublic"
    },
    {
      "method": "GET",
      "path": "/api/rooms/:hotelId/availability",
      "auth": "none",
      "description": "Returns availability for a hotel given a date range.",
      "pathParams": {
        "hotelId": "string – MongoDB ObjectId"
      },
      "queryParams": {
        "checkIn": "string (required) – ISO date",
        "checkOut": "string (required) – ISO date"
      },
      "response": {
        "available": "boolean",
        "bookedDates": ["string"],
        "blockedDates": ["string"]
      }
    },
    {
      "method": "POST",
      "path": "/api/rooms/:hotelId/booking-request",
      "auth": "none",
      "description": "Submits a guest booking request (pending, no payment). Email confirmation sent to guest.",
      "pathParams": {
        "hotelId": "string – MongoDB ObjectId"
      },
      "requestBody": {
        "firstName": "string (required)",
        "lastName": "string (required)",
        "email": "string (required)",
        "phone": "string (optional)",
        "checkIn": "string (required) – ISO date",
        "checkOut": "string (required) – ISO date",
        "adultCount": "number (required)",
        "childCount": "number (optional)",
        "notes": "string (optional)"
      },
      "response": {
        "bookingId": "string",
        "status": "pending"
      }
    },
    {
      "method": "POST",
      "path": "/api/rooms/:hotelId/bookings",
      "auth": "bearer",
      "requiredRole": "user",
      "description": "Creates a confirmed booking for a logged-in user (Stripe payment flow).",
      "pathParams": {
        "hotelId": "string"
      },
      "requestBody": {
        "checkIn": "string",
        "checkOut": "string",
        "adultCount": "number",
        "childCount": "number",
        "paymentIntentId": "string"
      }
    },

    {
      "group": "My Hotels (Owner/Admin)",
      "basePath": "/api/my-hotels",
      "requiredRole": "hotel_owner or admin"
    },
    {
      "method": "POST",
      "path": "/api/my-hotels",
      "auth": "bearer",
      "requiredRole": "hotel_owner|admin",
      "description": "Creates a new hotel listing. Supports multipart/form-data for image uploads.",
      "requestBody": "multipart/form-data – hotel fields + imageFiles[]"
    },
    {
      "method": "GET",
      "path": "/api/my-hotels",
      "auth": "bearer",
      "requiredRole": "hotel_owner|admin",
      "description": "Returns all hotels owned by the authenticated user."
    },
    {
      "method": "GET",
      "path": "/api/my-hotels/:id",
      "auth": "bearer",
      "requiredRole": "hotel_owner|admin",
      "description": "Returns a single hotel owned by the authenticated user.",
      "pathParams": {
        "id": "string – MongoDB ObjectId"
      }
    },
    {
      "method": "PUT",
      "path": "/api/my-hotels/:hotelId",
      "auth": "bearer",
      "requiredRole": "hotel_owner|admin",
      "description": "Updates an existing hotel listing. Supports multipart/form-data for image replacement.",
      "pathParams": {
        "hotelId": "string – MongoDB ObjectId"
      }
    },

    {
      "group": "Bookings Management (Admin/Owner)",
      "basePath": "/api/bookings"
    },
    {
      "method": "GET",
