    {
      "method": "GET",
      "path": "/api/onenote/sections",
      "auth": "session (Microsoft Graph)",
      "description": "Lists sections in a notebook.",
      "queryParams": {
        "notebookId": "string (optional)"
      }
    },
    {
      "method": "GET",
      "path": "/api/onenote/pages",
      "auth": "session (Microsoft Graph)",
      "description": "Lists pages in a section.",
      "queryParams": {
        "sectionId": "string (optional)"
      }
    },
    {
      "method": "GET",
      "path": "/api/onenote/prenotazioni/bookings",
      "auth": "session (Microsoft Graph)",
      "description": "Reads and parses the Prenotazioni OneNote section, returning structured booking records."
    },
    {
      "method": "GET",
      "path": "/api/onenote/pages/:pageId",
