        "id": "string"
      },
      "requestBody": {
        "decision": "approved | rejected",
        "reason": "string (optional) – rejection reason"
      }
    },
    {
      "method": "PUT",
      "path": "/api/bookings/:id",
      "auth": "bearer",
      "requiredRole": "hotel_owner|admin",
