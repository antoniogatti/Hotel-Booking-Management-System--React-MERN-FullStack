      "pathParams": {
        "id": "string"
      }
    },
    {
      "method": "DELETE",
      "path": "/api/bookings/:id",
      "auth": "bearer",
      "requiredRole": "admin",
      "description": "Permanently deletes a booking. Admin only.",
      "pathParams": {
        "id": "string"
      }
    },
    {
      "method": "GET",
      "path": "/api/bookings/dashboard/summary",
      "auth": "bearer",
