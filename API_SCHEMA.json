      "pathParams": {
        "pageId": "string"
      }
    },
    {
      "method": "POST",
      "path": "/api/onenote/ai/extract-booking",
      "auth": "session (Microsoft Graph)",
      "description": "Uses Azure OpenAI to extract structured booking data from raw OneNote page text.",
      "requestBody": {
        "text": "string (optional) – raw text to extract from",
