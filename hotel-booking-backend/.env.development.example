# Backend development profile (local)
NODE_ENV=development
PORT=5000

# Database
MONGODB_CONNECTION_STRING=mongodb://localhost:27017/hotel-booking

# Security
JWT_SECRET_KEY=replace_with_long_random_secret

# CORS
FRONTEND_URL=http://localhost:5174
# Optional comma-separated list for additional local origins
FRONTEND_URLS=http://localhost:5174,http://localhost:5173

# Public backend URL for OAuth callback generation in local tests
BACKEND_URL=http://localhost:5000

# Microsoft Entra OAuth
MS_ENTRA_CLIENT_ID=replace_with_client_id
MS_ENTRA_CLIENT_SECRET=replace_with_client_secret
MS_ENTRA_TENANT_ID=common

# Contact form mail delivery (Microsoft Graph sendMail)
CONTACT_MAIL_SENDER=info@palazzopintobnb.com
CONTACT_MAIL_INBOX=info@palazzopintobnb.com
CONTACT_MAIL_SUBJECT_PREFIX=Palazzo Pinto B&B 
CONTACT_MAIL_CONFIRMATION_SUBJECT=Message Sent - Confirmation

# Payments
STRIPE_API_KEY=sk_test_replace_me
