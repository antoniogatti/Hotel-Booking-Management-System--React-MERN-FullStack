# Backend production profile (Azure App Service)
NODE_ENV=production
PORT=8080

# Database (Cosmos DB for Mongo or MongoDB Atlas)
MONGODB_CONNECTION_STRING=replace_with_production_connection_string

# Security
JWT_SECRET_KEY=replace_with_long_random_secret

# CORS - primary frontend origin
FRONTEND_URL=https://palazzopinto-web-xxxx.azurewebsites.net
# Optional comma-separated additional origins (preview domains, custom domain)
FRONTEND_URLS=https://palazzopinto-web-xxxx.azurewebsites.net,https://www.your-domain.com

# Public backend URL used for OAuth callbacks and docs links
BACKEND_URL=https://palazzopinto-api-xxxx.azurewebsites.net

# Microsoft Entra OAuth
MS_ENTRA_CLIENT_ID=replace_with_client_id
MS_ENTRA_CLIENT_SECRET=replace_with_client_secret
MS_ENTRA_TENANT_ID=replace_with_tenant_or_common

# Media
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret

# Payments
STRIPE_API_KEY=sk_live_or_sk_test_replace_me
