# ================================================
# Hotel Booking Backend - Environment Variables
# ================================================
# Copy this file to .env and fill in your values

# ================================================
# SERVER CONFIGURATION
# ================================================
# Port number (Coolify/VPS will set this automatically in production)
PORT=5000

# Node environment (development, production, test)
NODE_ENV=development

# ================================================
# DATABASE CONFIGURATION
# ================================================
# MongoDB connection string (MongoDB Atlas or local)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_CONNECTION_STRING=your_mongodb_connection_string_here

# ================================================
# AUTHENTICATION & SECURITY
# ================================================
# JWT Secret Key (use a strong, random string)
# Generate with: openssl rand -base64 512
JWT_SECRET_KEY=your_jwt_secret_key_here

# ================================================
# FRONTEND & BACKEND CONFIGURATION
# ================================================
# Frontend URL for CORS (your React app URL)
# Local development: http://localhost:5174
# Production: https://palazzopinto-web-xxxx.azurewebsites.net
FRONTEND_URL=http://localhost:5174

# Optional additional allowed origins (comma-separated)
# Example: https://palazzopinto-web-xxxx.azurewebsites.net,https://www.your-domain.com
FRONTEND_URLS=

# Backend public URL (for Swagger docs, OAuth callbacks, etc.)
# Local: leave unset (defaults to http://localhost:PORT)
# Production: https://palazzopinto-api-xxxx.azurewebsites.net
# BACKEND_URL=https://palazzopinto-api-xxxx.azurewebsites.net

# Microsoft Entra OAuth (Microsoft-only sign-in)
MS_ENTRA_CLIENT_ID=your_microsoft_client_id
MS_ENTRA_CLIENT_SECRET=your_microsoft_client_secret
# Use your tenant id for single-tenant, or "common" for multi-tenant
MS_ENTRA_TENANT_ID=common

# Contact form mail delivery (Microsoft Graph sendMail)
# Must be a mailbox in your tenant (for this project: info@palazzopintobnb.com)
CONTACT_MAIL_SENDER=info@palazzopintobnb.com
# Inbox destination for contact notifications
CONTACT_MAIL_INBOX=info@palazzopintobnb.com
# Prefix to help inbox filtering/rules
CONTACT_MAIL_SUBJECT_PREFIX=[PalazzoPinto][ContactForm]
# User confirmation email subject
CONTACT_MAIL_CONFIRMATION_SUBJECT=Message Sent - Confirmation

# ================================================
# STRIPE PAYMENT CONFIGURATION
# ================================================
# Stripe API key for payment processing
# Get from: https://dashboard.stripe.com/apikeys
# Use test key for development: sk_test_...
# Use live key for production: sk_live_...
STRIPE_API_KEY=your_stripe_secret_key_here

# ================================================
# OPTIONAL CONFIGURATION
# ================================================
# Add any additional environment variables below
